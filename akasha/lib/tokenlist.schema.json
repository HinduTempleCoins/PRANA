{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://prana.chain/akasha/tokenlist.schema.json",
  "title": "Akasha Token List",
  "description": "A list of ERC-20 tokens recognized by the Akasha wallet for a single chain. Modeled on the Uniswap token-list shape, trimmed to PRANA needs.",
  "type": "object",
  "required": ["name", "chainId", "tokens"],
  "additionalProperties": true,
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "chainId": { "type": "integer", "minimum": 1 },
    "version": {
      "type": "object",
      "properties": {
        "major": { "type": "integer", "minimum": 0 },
        "minor": { "type": "integer", "minimum": 0 },
        "patch": { "type": "integer", "minimum": 0 }
      }
    },
    "tokens": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["address", "symbol", "name", "decimals"],
        "additionalProperties": true,
        "properties": {
          "address": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
          "symbol": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "decimals": { "type": "integer", "minimum": 0, "maximum": 36 },
          "logoURI": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
