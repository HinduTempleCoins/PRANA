# the pre-commit guard contains secret/brand keywords as detection patterns (would trip itself)
/tools/git-hooks/

# Akasha wallet front-end — private product, local-only until published
/akasha/node_modules/
/akasha/

# adapters reuse contracts/node_modules via a local symlink — never commit it
/tools/adapters/node_modules
